@startuml
!include _common.puml

title Fluxo de Pagamento

|Admin|
start
:Configurar Gateway;
if (Provedor?) then ([PIX])
  :Definir Chave PIX + Unidade;
else ([Mercado Pago])
  :Definir Access Token + Public Key;
endif
:Selecionar Canal (Portal);
:Ativar;

|Sistema|
:Gateway Ativo (portal);

:Tutor / Recepcionista|
if (Gateway?) then ([PIX])
  :Acessa Fatura em Aberto;
  :Clique em Gerar QR Code;
else ([Mercado Pago])
  :Acessa Fatura em Aberto;
  :Clique em Pagar Online;
endif

|Sistema|
if (Gateway?) then ([PIX])
  :PixService::generateQRCode();
  :Gerar Payload EMV + QR Code;
  :Exibir QR Code na Tela;
else ([Mercado Pago])
  :MercadoPagoProvider::checkout();
  if (Sandbox?) then ([sim])
    :Usar sandbox_init_point;
  else ([não])
    :Usar init_point;
  endif
  :Redirecionar ao Checkout MP;
endif

|Tutor|
if (Gateway?) then ([PIX])
  :Escanear QR Code;
  :Confirmar Pagamento no App;
  |Recepcionista|
  :Registrar Pagamento Manualmente;
else ([Mercado Pago])
  :Preencher Dados Cartão/Saldo;
  :Confirmar Pagamento;
  |Sistema|
  :Receber Retorno (querystring);
  :Consultar API MP via processWebhook();
  :Validar Status Real do Pagamento;
endif

|Sistema|
:Atualizar Fatura (status = paid);
:Disparar InvoicePaid;

stop
@enduml
