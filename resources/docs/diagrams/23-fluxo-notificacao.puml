@startuml
!include _common.puml

title Fluxo de Notificações

|Sistema|
start
:Evento de Negócio;
:Verificar Preferências;

if (Tutor optou por notifs?) then ([não])
  stop
endif

:Definir Prioridade de Canal;

split
  :WhatsApp;
  note right
    Provedores:
    - Z-API
    - Weni
    - Cloud API (Meta)
    - Twilio
  end note
split again
  :SMS (fallback);
  note right
    Provedores:
    - Twilio
    - Zenvio
    - Amazon SNS
  end note
split again
  :E-mail;
  note right
    Provedores:
    - MailerSend
    - SMTP
    - Mailgun
    - SES
    - SendGrid
  end note
endsplit

:Registrar NotificationLog;

if (Falhou?) then ([sim])
  :3 tentativas + desativar canal;
  stop
else ([não])
  |Tutor|
  :Notificação Recebida;
  stop
endif
@enduml
