@startuml
!include _common.puml

title Fluxo de Agendamento e Consulta

|Sistema|
start
if (Origem?) then ([Portal])
  |Tutor|
  :Acessa Portal;
  :Selecionar Serviço + Unidade;
  |Sistema|
  :VetAvailabilityService::getAvailableVets();
  :Filtrar por branch_id + is_vet_shift;
  :Exibir Horários Disponíveis;
  |Tutor|
  :Escolher Veterinário + Horário;
  :Confirmar Agendamento;
else ([Recepção])
  |Recepcionista|
  :Calendário + Dados Tutor;
  :Selecionar Unidade + Profissional;
  :Agendar;
endif

|Sistema|
:Status: Agendado;

repeat
  :pending;

  |Recepcionista|
  if (Tutor Confirmou?) then ([não])
  else ([sim])
    break
  endif
repeat while ([não]) is (Aguardando)

|Sistema|
:Status: Confirmado;

:Lembrete 24h;

:Lembrete 2h;

|Veterinário|
:Iniciar Consulta;
:Status: Em Andamento;

:Consulta Realizada;

if (Concluída?) then ([não])
  |Sistema|
  :Status: Cancelado;
  :Reagenda;
  -->|Volta|
else ([sim])
  if (Tutor Presente?) then ([sim])
    |Sistema|
    :Status: Finalizado;
    :Auto-Faturamento;
  else ([não])
    |Sistema|
    :Status: Não Compareceu;
  endif
endif

stop
@enduml
