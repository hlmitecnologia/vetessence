@startuml
!include _common.puml

title Fluxo de Faturamento, NFSe, NFC-e e Comissões

|Veterinário|
start
:Fatura Gerada;
:Adicionar Itens/Serviços;

|Tutor / Recepcionista|
:Pagar (Dinheiro/Cartão/PIX/MP);

|Sistema|
if (Pago?) then ([não])
  stop
else ([sim])
  :InvoicePaid (evento);
  if (Tem Itens Serviço?) then ([não])
  else ([sim])
    if (NFSe Config?) then ([não])
    else ([sim])
      :Emitir NFSe;
      :Processar NFSe;
      :Salvar XML + PDF;
      |Tutor|
      :Receber NFSe por E-mail;
    endif
  endif
  |Sistema|
  if (Tem Itens Produto?) then ([não])
  else ([sim])
    if (NFC-e Config?) then ([não])
    else ([sim])
      :Emitir NFC-e (modelo 65);
      :Processar NFC-e;
      :Salvar XML + DANFE;
      :Deduzir Estoque;
    endif
  endif
  |Sistema|
  if (Comissão Config?) then ([não])
  else ([sim])
    :Calcular Comissão;
    :Commission pending;
    |Financeiro|
    :Financeiro paga;
  endif
  |Sistema|
  if (Conciliação Automática?) then ([não])
  else ([sim])
    :Transação Bancária;
    :Reconcilied;
  endif
endif

stop
@enduml
